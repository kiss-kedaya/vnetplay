{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VNetPlay",
  "version": "0.1.0",
  "identifier": "com.kedaya.vnetplay",
  "build": {
    "frontendDist": "../../app/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VNetPlay",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
